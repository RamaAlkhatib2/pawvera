rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles & subcollections ──────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // My Pets
      match /pets/{petId} {
        allow read, write: if request.auth != null
                            && request.auth.uid == userId;
      }

      // Reminders
      match /reminders/{reminderId} {
        allow read, write: if request.auth != null
                            && request.auth.uid == userId;
      }

      // Pet supplies store (provider uid == userId): promotions & audit
      match /pet_store_offers/{offerId} {
        allow read, write: if request.auth != null
                            && request.auth.uid == userId;
      }

      match /pet_store_audit_logs/{logId} {
        allow read: if request.auth != null
                     && request.auth.uid == userId;
        allow create: if request.auth != null
                       && request.auth.uid == userId;
        allow update, delete: if false;
      }
    }

    // ── Bookings (my_bookings_page, database_service) ────────────────────────
    match /bookings/{bookingId} {
      allow read: if request.auth != null
                   && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                     && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null
                              && request.auth.uid == resource.data.userId;
    }

    // ── Adoption pets ────────────────────────────────────────────────────────
    match /adoption_pets/{petId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                     && request.auth.uid == request.resource.data.postedBy;
      allow update, delete: if request.auth != null
                              && request.auth.uid == resource.data.postedBy;
    }

    // ── Online store: stores & products ─────────────────────────────────────
    // Stores are modeled as provider user docs; `storeId` in products/orders
    // is the provider's auth uid (so `storeId == request.auth.uid` for the owner).
    // Legacy `stores/{storeId}.ownerId` lookups remain as a fallback.
    match /stores/{storeId} {
      // Public read: store directory is safe to browse without auth (writes stay locked).
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                              && request.auth.uid == resource.data.ownerId;

      match /products/{productId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                      && request.auth.uid == get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId;
      }
    }

    // Top-level products collection
    match /products/{productId} {
      allow read: if request.auth != null;
      // Split create vs update/delete because `resource` is null on create.
      allow create: if request.auth != null
                     && (
                       // New model: storeId == provider uid
                       request.auth.uid == request.resource.data.storeId
                       // Legacy fallback: stores/{storeId}.ownerId
                       || (exists(/databases/$(database)/documents/stores/$(request.resource.data.storeId))
                           && request.auth.uid == get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId)
                     );
      allow update, delete: if request.auth != null
                             && (
                               request.auth.uid == resource.data.storeId
                               || (exists(/databases/$(database)/documents/stores/$(resource.data.storeId))
                                   && request.auth.uid == get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId)
                             );
    }

    // ── Orders ───────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if request.auth != null
                   && (request.auth.uid == resource.data.userId
                    || request.auth.uid == resource.data.storeId
                    || (exists(/databases/$(database)/documents/stores/$(resource.data.storeId))
                        && request.auth.uid == get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId));
      allow create: if request.auth != null
                     && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
                     && (request.auth.uid == resource.data.userId
                      || request.auth.uid == resource.data.storeId
                      || (exists(/databases/$(database)/documents/stores/$(resource.data.storeId))
                          && request.auth.uid == get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId));
      allow delete: if false;
    }

    // ── Reviews ──────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Cart & Wishlist ──────────────────────────────────────────────────────
    match /users_cart/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;

      match /cart_items/{itemId} {
        allow read, write: if request.auth != null
                            && request.auth.uid == userId;
      }

      match /wishlist_items/{itemId} {
        allow read, write: if request.auth != null
                            && request.auth.uid == userId;
      }
    }

    // ── Service provider shops ───────────────────────────────────────────────
    match /service_shops/{shopId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                              && request.auth.uid == resource.data.ownerId;

      match /services/{serviceId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                      && request.auth.uid == get(/databases/$(database)/documents/service_shops/$(shopId)).data.ownerId;
      }

      match /offers/{offerId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                      && request.auth.uid == get(/databases/$(database)/documents/service_shops/$(shopId)).data.ownerId;
      }

      match /audit_logs/{logId} {
        allow read: if request.auth != null
                     && request.auth.uid == get(/databases/$(database)/documents/service_shops/$(shopId)).data.ownerId;
        allow create: if request.auth != null;
        allow update, delete: if false;
      }

      // ── Bookings (subcollection under each shop) ──────────────────────────
      match /bookings/{bookingId} {
        allow read: if request.auth != null
                     && (request.auth.uid == resource.data.userId
                      || request.auth.uid == get(/databases/$(database)/documents/service_shops/$(shopId)).data.ownerId);
        allow create: if request.auth != null;
        allow update: if request.auth != null
                       && (request.auth.uid == resource.data.userId
                        || request.auth.uid == get(/databases/$(database)/documents/service_shops/$(shopId)).data.ownerId);
        allow delete: if false;
      }
    }

    // ── Reminder types (admin-managed, globally readable) ────────────────────
    match /reminder_types/{typeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── User notifications ───────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read, update, delete: if request.auth != null
                                   && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                     && request.auth.uid == request.resource.data.userId;
    }

    // ── Conversations & Messages ─────────────────────────────────────────────
    match /conversations/{convId} {
      allow read: if request.auth != null
                   && (resource == null
                    || request.auth.uid in resource.data.participants);
      allow create: if request.auth != null
                     && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
                     && request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if request.auth != null
                     && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if request.auth != null
                       && request.auth.uid == request.resource.data.senderId
                       && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow update, delete: if false;
      }
    }

  }
}
