rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───────────────────────────────────────────────────────
    // Service Provider Shops
    // Only the owner can write to their shop document.
    // Anyone authenticated can read (for discovery).
    // ───────────────────────────────────────────────────────
    match /service_shops/{shopId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;

      // Subcollections: services, offers, audit_logs
      // Only the shop owner can write; anyone can read active data.
      match /services/{serviceId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                      && request.auth.uid == get(/databases/$(database)/documents/service_shops/$(shopId)).data.ownerId;
      }

      match /offers/{offerId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                      && request.auth.uid == get(/databases/$(database)/documents/service_shops/$(shopId)).data.ownerId;
      }

      match /audit_logs/{logId} {
        allow read: if request.auth != null
                     && request.auth.uid == get(/databases/$(database)/documents/service_shops/$(shopId)).data.ownerId;
        allow create: if request.auth != null; // System writes via controller
        allow delete: if false; // Never delete audit logs
        allow update: if false; // Never update audit logs
      }
    }

    // ───────────────────────────────────────────────────────
    // Service Bookings
    // The booking owner (userId) or the shop owner can read/write.
    // ───────────────────────────────────────────────────────
    match /service_bookings/{bookingId} {
      allow read: if request.auth != null
                   && (request.auth.uid == resource.data.userId
                    || request.auth.uid == get(/databases/$(database)/documents/service_shops/$(resource.data.shopId)).data.ownerId);
      allow create: if request.auth != null;
      allow update: if request.auth != null
                     && (request.auth.uid == resource.data.userId
                      || request.auth.uid == get(/databases/$(database)/documents/service_shops/$(resource.data.shopId)).data.ownerId);
      allow delete: if false; // Bookings should be cancelled, not deleted
    }

    // ───────────────────────────────────────────────────────
    // Existing rules below (online store, users, etc.)
    // ───────────────────────────────────────────────────────

    // User profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /pets/{petId} {
        allow read: if request.auth != null
                     && request.auth.uid == userId;
        allow write: if request.auth != null
                      && request.auth.uid == userId;
      }
      match /reminders/{reminderId} {
        allow read: if request.auth != null
                     && request.auth.uid == userId;
        allow write: if request.auth != null
                      && request.auth.uid == userId;
      }
    }

    // Online stores (product shops)
    match /stores/{storeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;

      match /products/{productId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                      && request.auth.uid == get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId;
      }
    }

    // Orders
    match /orders/{orderId} {
      allow read: if request.auth != null
                   && (request.auth.uid == resource.data.userId
                    || request.auth.uid == get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId);
      allow create: if request.auth != null
                     && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
                     && (request.auth.uid == resource.data.userId
                      || request.auth.uid == get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId);
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // User cart & wishlist
    match /users_cart/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    // Products (top-level for direct access)
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                    && request.auth.uid == get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId;
    }
  }
}